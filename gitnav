#  INSTALL HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
def offer_install():
    print(f"\n{C.BCYAN}╔{'═'*58}╗{C.RESET}")
    print(f"{C.BCYAN}║{C.RESET}  {C.BOLD}GitNav — First Run · System-Wide Install?{C.RESET}           {C.BCYAN}║{C.RESET}")
    print(f"{C.BCYAN}╠{'═'*58}╣{C.RESET}")
    print(f"{C.BCYAN}║{C.RESET}  Install to {C.BWHITE}{INSTALL_TO}{C.RESET}              {C.BCYAN}║{C.RESET}")
    print(f"{C.BCYAN}║{C.RESET}  Enables: {C.BYELLOW}gitnav{C.RESET} / {C.BYELLOW}gitnav -cli{C.RESET} / {C.BYELLOW}gitnav -ui{C.RESET}              {C.BCYAN}║{C.RESET}")
    print(f"{C.BCYAN}╚{'═'*58}╝{C.RESET}")
    ans = input(f"\n  {C.BYELLOW}▸{C.RESET} Install system-wide? [y/N]: ").strip().lower()
    if ans == "y": _do_install()
    FIRST_RUN.touch()

def _do_install():
    src = os.path.realpath(__file__)
    try:
        shutil.copy2(src, INSTALL_TO)
        os.chmod(INSTALL_TO, 0o755)
        print(f"  {C.BGREEN}✓ Installed to {INSTALL_TO}{C.RESET}")
        print(f"  {C.DIM}Run: gitnav | gitnav -cli | gitnav -ui{C.RESET}")
    except PermissionError:
        try:
            subprocess.run(["sudo","cp",src,INSTALL_TO],check=True)
            subprocess.run(["sudo","chmod","755",INSTALL_TO],check=True)
            print(f"  {C.BGREEN}✓ Installed (sudo) to {INSTALL_TO}{C.RESET}")
        except Exception as e:
            print(f"  {C.BRED}✗ Install failed: {e}{C.RESET}")
            print(f"  {C.DIM}Manual: sudo cp {src} {INSTALL_TO} && sudo chmod 755 {INSTALL_TO}{C.RESET}")


