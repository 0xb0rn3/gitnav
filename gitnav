#  ENTRY POINT
# ═══════════════════════════════════════════════════════════════════════════════
def main():
    parser = argparse.ArgumentParser(
        prog="gitnav",
        description="Enhanced GitHub Repository Navigator v2.0.0",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent(f"""\
            Modes:
              gitnav            prompt for CLI or UI
              gitnav -cli       classic text-menu mode
              gitnav -ui        full-screen interactive TUI

            Options:
              -u USERNAME       pre-load a GitHub username
              -t TOKEN[,...]    GitHub PAT (comma-separate multiple for rotation)
              --install         install system-wide to {INSTALL_TO}
              --backup-dir DIR  override default backup root (~/.gitnav_backups)

            Clone strategies (selected at runtime):
              blobless  --filter=blob:none  trees/commits local, blobs on demand
              treeless  --filter=tree:0     commits local only
              shallow   --depth 1           last commit only
              full      complete clone

            Multi-token example (higher rate limits):
              gitnav -t ghp_token1,ghp_token2,ghp_token3

            Dev: oxbv1 | oxborn3  ·  oxborn3.com  ·  contact@oxborn3.com
            Repo: github.com/0xb0rn3/gitnav   v{VERSION}
        """)
    )
    parser.add_argument("-cli","--cli",   action="store_true", help="CLI menu mode")
    parser.add_argument("-ui", "--ui",    action="store_true", help="Interactive TUI mode")
    parser.add_argument("-u",  "--user",  metavar="USERNAME",  help="GitHub username")
    parser.add_argument("-t",  "--token", metavar="TOKEN[,…]", help="GitHub PAT(s), comma-separated")
    parser.add_argument("--install",      action="store_true", help="Install to system PATH")
    parser.add_argument("--backup-dir",   metavar="DIR",       help="Override backup root directory")
    parser.add_argument("--version",      action="version",    version=f"GitNav v{VERSION}")
    args = parser.parse_args()

    if args.install:
        _do_install(); return

    # Override backup root if provided
    if args.backup_dir:
        global BACKUP_ROOT
        BACKUP_ROOT = Path(args.backup_dir).expanduser().resolve()

    # Load tokens into pool
    if args.token:
        _token_pool.add(args.token)

    if not FIRST_RUN.exists():
        offer_install()

    if args.cli and args.ui:
        print(f"{C.BRED}✗  --cli and --ui are mutually exclusive.{C.RESET}"); sys.exit(1)

    api = GitHubAPI()   # token handled via pool

    if args.cli:
        mode = "cli"
    elif args.ui:
        mode = "ui"
    else:
        clear(); print(BANNER)
        print(f"  {C.BCYAN}Select interface mode:{C.RESET}\n")
        print(f"  {C.BWHITE}1){C.RESET}  {C.BYELLOW}CLI{C.RESET}  — Classic text menu  (any terminal)")
        print(f"  {C.BWHITE}2){C.RESET}  {C.BYELLOW}UI{C.RESET}   — Full-screen TUI    (recommended)\n")
        while True:
            choice = input(f"  {C.BYELLOW}▸{C.RESET} Mode [1/cli  or  2/ui]: ").strip().lower()
            if choice in ("1","cli"): mode="cli"; break
            if choice in ("2","ui"):  mode="ui";  break

    if mode == "cli":
        CLI(api, args.user or "").run()
    else:
        TUI(api, args.user or "").run()

if __name__ == "__main__":
    main()
