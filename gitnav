    def _pick_repo(self, prompt="Repository name"):
        repos = self._load_repos()
        if not repos:
            print(f"  {C.BRED}No repositories found.{C.RESET}"); return None
        name = self._prompt(prompt + " (name or # number)")
        if name.isdigit():
            idx = int(name) - 1
            if 0 <= idx < len(repos): return repos[idx]["name"]
        for r in repos:
            if r["name"] == name: return name
        matches = [r["name"] for r in repos if name.lower() in r["name"].lower()]
        if len(matches) == 1: return matches[0]
        if matches:
            print(f"  {C.BYELLOW}Matches:{C.RESET} " + ", ".join(matches[:8]))
        return name or None

    def ask_username(self):
        print()
        while True:
            u = self._prompt("GitHub username")
            if not u: continue
            with Loader(f"Verifying @{u}"):
                try:
                    self.api.user(u); self.username = u
                    print(f"  {C.BGREEN}✓{C.RESET} Loaded profile for {C.BOLD}@{u}{C.RESET}"); return
                except Exception as e:
                    print(f"  {C.BRED}✗{C.RESET} {e}")

    def run(self):
        clear(); print(BANNER)
        if not self.username: self.ask_username()
        while True:
            self._show_menu()
            choice = self._prompt("Choice", "0")
            if choice.isdigit():
                idx = int(choice) - 1
                if 0 <= idx < len(self.MENU):
                    self._dispatch(self.MENU[idx][2]); continue
            print(f"  {C.BRED}Invalid choice.{C.RESET}")

    def _show_menu(self):
        # Rate limit indicator
        rem  = self.api.rate_remaining
        lim  = self.api.rate_limit_val
        toks = _token_pool.count()
        rl_str = ""
        if rem is not None:
            col = C.BGREEN if rem > 100 else (C.BYELLOW if rem > 20 else C.BRED)
            rl_str = f"  {C.DIM}API:{C.RESET} {col}{rem}{C.RESET}{C.DIM}/{lim or '?'}{C.RESET}"
            if toks > 0:
                rl_str += f"  {C.DIM}tokens:{C.RESET} {C.BCYAN}{_token_pool.fresh_count()}/{toks}{C.RESET}"

        print(f"\n  {C.BCYAN}╔{'═'*48}╗{C.RESET}")
        uline = f"  @{self.username}"
        pad   = max(0, 46 - len(uline) - len(strip_ansi(rl_str)))
        print(f"  {C.BCYAN}║{C.RESET} {C.BOLD}{uline}{C.RESET}{rl_str}{' '*pad} {C.BCYAN}║{C.RESET}")
        print(f"  {C.BCYAN}╠{'═'*48}╣{C.RESET}")
        for i, (emoji, label, key) in enumerate(self.MENU, 1):
            is_exit   = key == "exit"
            is_backup = key in ("backup", "browse_backup")
            col = C.BRED if is_exit else (C.BMAGENTA if is_backup else C.BWHITE)
            n   = f"{C.DIM}{i:>2}{C.RESET}"
            line = f"{col}{label:<35}{C.RESET}"
            print(f"  {C.BCYAN}║{C.RESET}  {n}  {emoji}  {line}{C.BCYAN}║{C.RESET}")
        print(f"  {C.BCYAN}╚{'═'*48}╝{C.RESET}")

    def _dispatch(self, action):
        try:    getattr(self, f"_do_{action}")()
        except RuntimeError as e: print(f"\n  {C.BRED}⚠  {e}{C.RESET}")
        except KeyboardInterrupt:  print(f"\n  {C.DIM}Cancelled.{C.RESET}")
        input(f"\n  {C.DIM}[Enter to continue]{C.RESET}")

    # ── CLI Actions ─────────────────────────────────────────────────────────────
    def _do_list(self):
        repos = self._load_repos()
        self._header("Repositories", "📋"); self._sep()
        state = _backup_state.get_user(self.username)
        bdir  = BACKUP_ROOT / self.username
        for i, r in enumerate(repos, 1):
            lang  = f"{C.BBLUE}[{(r.get('language') or '—'):>10}]{C.RESET}"
            stars = f"{C.BYELLOW}★{fmt_num(r.get('stargazers_count',0)):<5}{C.RESET}"
            name  = f"{C.BWHITE}{r['name']}{C.RESET}"
            priv  = f" {C.BRED}[private]{C.RESET}" if r.get("private") else ""
            # Backup badge
            if (bdir / r["name"] / ".git").exists():
                bk = f" {C.BGREEN}[bk]{C.RESET}"
            else:
                bk = ""
            print(f"  {C.DIM}{i:>3}.{C.RESET}  {lang}  {stars}  {name}{priv}{bk}")
        self._sep()
        print(f"  {C.DIM}{len(repos)} repositories{C.RESET}")

    def _do_detail(self):
        repos = self._load_repos()
        self._header("Detailed Repository List", "📋")
        for r in repos:
            lang = r.get("language") or "—"
            stars= r.get("stargazers_count", 0)
            forks= r.get("forks_count", 0)
            size = fmt_size((r.get("size") or 0) * 1024)
            upd  = ago(r.get("updated_at"))
            desc = (r.get("description") or "No description")[:65]
            priv = f" {C.BRED}🔒{C.RESET}" if r.get("private") else ""
            print(f"\n  {C.BOLD}{C.BWHITE}{r['name']}{C.RESET}{priv}")
            print(f"  {C.DIM}{desc}{C.RESET}")
            print(f"  {C.BYELLOW}★{stars}{C.RESET}  {C.BCYAN}⑂{forks}{C.RESET}  "
                  f"{C.BBLUE}[{lang}]{C.RESET}  {C.DIM}{size} · {upd}{C.RESET}")
            self._sep("·", 60)

    def _do_search(self):
        self._header("Search Repositories", "🔍")
        repos = self._load_repos()
        q = self._prompt("Search (name / description / language)")
        if not q: return
        ql   = q.lower()
        hits = [r for r in repos if
                ql in (r.get("name") or "").lower() or
                ql in (r.get("description") or "").lower() or
                ql in (r.get("language") or "").lower()]
        print(f"\n  {C.BGREEN}{len(hits)}{C.RESET} match(es) for {C.BYELLOW}'{q}'{C.RESET}\n")
        for r in hits:
            desc = truncate(r.get("description") or "—", 55)
            print(f"  {C.BWHITE}{r['name']:<35}{C.RESET}  "
                  f"{C.BBLUE}[{(r.get('language') or '—'):<10}]{C.RESET}  "
                  f"{C.DIM}{desc}{C.RESET}")

    def _do_stats(self):
        repos = self._load_repos()
        self._header("Repository Statistics", "📊")
        total_stars = sum(r.get("stargazers_count",0) for r in repos)
        total_forks = sum(r.get("forks_count",0) for r in repos)
        total_size  = sum((r.get("size") or 0) for r in repos) * 1024
        langs       = defaultdict(int)
        for r in repos:
            l = r.get("language")
            if l: langs[l] += 1
        public = sum(1 for r in repos if not r.get("private"))
        print(f"\n  {C.BBLUE}Total repos  {C.RESET} {len(repos)}")
        print(f"  {C.BYELLOW}Total stars  {C.RESET} {fmt_num(total_stars)}")
        print(f"  {C.BCYAN}Total forks  {C.RESET} {fmt_num(total_forks)}")
        print(f"  {C.BMAGENTA}Total size   {C.RESET} {fmt_size(total_size)}")
        print(f"  {C.BGREEN}Public       {C.RESET} {public}")
        print(f"  {C.BRED}Private      {C.RESET} {len(repos)-public}")
        if langs:
            print(f"\n  {C.BOLD}Language breakdown:{C.RESET}")
            top = sorted(langs.items(), key=lambda x: -x[1])[:12]
            bw  = 28; mx = max(v for _,v in top)
            for lang, cnt in top:
                filled = round(bw * cnt / mx)
                bar = f"{C.BBLUE}{'█'*filled}{C.DIM}{'░'*(bw-filled)}{C.RESET}"
                print(f"  {lang:<16} {bar} {cnt}")

    def _do_clone(self):
        self._header("Clone Repository", "📥")
        repo = self._pick_repo("Repository to clone")
        if not repo: return
        dest = self._prompt("Destination directory", ".")

        # Strategy selection
        print(f"\n  {C.BBLUE}Clone strategy:{C.RESET}")
        print(f"  {C.DIM}1){C.RESET} full      — complete clone (slow on large repos)")
        print(f"  {C.DIM}2){C.RESET} blobless  — {C.BGREEN}recommended{C.RESET} — no blobs until needed")
        print(f"  {C.DIM}3){C.RESET} shallow   — last commit only (fastest, limited history)")
        print(f"  {C.DIM}4){C.RESET} treeless  — commits only (laziest, best for big repos)")
        strat_map = {"1":"full","2":"blobless","3":"shallow","4":"treeless",
                     "full":"full","blobless":"blobless","shallow":"shallow","treeless":"treeless"}
        s = self._prompt("Strategy [1-4 or name]", "2")
        strategy = strat_map.get(s.lower(), "blobless")

        jobs = self._prompt("Parallel jobs (default 4)", "4")
        try: jobs = int(jobs)
        except: jobs = 4

        url  = f"https://github.com/{self.username}/{repo}.git"
        path = os.path.join(dest, repo)
        print(f"\n  {C.DIM}Cloning {url}{C.RESET}")
        print(f"  {C.DIM}Strategy: {strategy}  jobs: {jobs}{C.RESET}\n")

        def on_line(l): print(f"  {C.DIM}{l}{C.RESET}")
        rc, err = CloneEngine.clone(url, path, strategy=strategy, jobs=jobs, on_line=on_line)
        if rc == 0: print(f"\n  {C.BGREEN}✓ Cloned to {path}{C.RESET}")
        else:       print(f"\n  {C.BRED}✗ Clone failed: {err}{C.RESET}")

    def _do_backup(self):
        """Backup all repos for current user with smart resume."""
        self._header("Backup All Repos", "💾")
        repos = self._load_repos()
        if not repos:
            print(f"  {C.BRED}No repositories found.{C.RESET}"); return

        # Backup dir
        default_dir = str(BACKUP_ROOT / self.username)
        bdir = self._prompt(f"Backup directory [{default_dir}]", default_dir)
        bdir = Path(bdir).expanduser().resolve()
        bdir.mkdir(parents=True, exist_ok=True)

        # Strategy
        print(f"\n  {C.BBLUE}Clone strategy for new repos:{C.RESET}")
        print(f"  {C.DIM}1){C.RESET} blobless {C.BGREEN}(recommended){C.RESET}  2) full  3) shallow  4) treeless")
        strat_map = {"1":"blobless","2":"full","3":"shallow","4":"treeless",
                     "blobless":"blobless","full":"full","shallow":"shallow","treeless":"treeless"}
        s = self._prompt("Strategy [1-4]", "1")
        strategy = strat_map.get(s.lower(), "blobless")

        jobs = self._prompt("Parallel jobs", "4")
        try: jobs = int(jobs)
        except: jobs = 4

        # Audit: what exists already
        state  = _backup_state.get_user(self.username)
        to_clone  = []
        to_update = []
        for r in repos:
            repo_path = bdir / r["name"]
            if (repo_path / ".git").exists():
                to_update.append(r)
            else:
                to_clone.append(r)

        print(f"\n  {C.BBLUE}Backup plan:{C.RESET}")
        print(f"  {C.BGREEN}New to clone :{C.RESET} {len(to_clone)}")
        print(f"  {C.BYELLOW}To update    :{C.RESET} {len(to_update)}")
        print(f"  {C.DIM}Destination  : {bdir}{C.RESET}")
        print()
        confirm = self._prompt("Proceed? [Y/n]", "y")
        if confirm.lower() == "n": return

        ok_clone = ok_update = failed = 0

        # ── Clone missing repos ────────────────────────────────────────────────
        if to_clone:
            print(f"\n  {C.BCYAN}━━ Cloning {len(to_clone)} new repos ━━{C.RESET}")
        for r in to_clone:
            url  = f"https://github.com/{self.username}/{r['name']}.git"
            dest = str(bdir / r["name"])
            print(f"\n  {C.BWHITE}→ {r['name']}{C.RESET}  {C.DIM}({r.get('language') or '—'}){C.RESET}")
            lines_buf = []
            def on_line(l, rb=lines_buf): rb.append(l); print(f"    {C.DIM}{l}{C.RESET}")
            rc, err = CloneEngine.clone(url, dest, strategy=strategy,
                                        jobs=jobs, on_line=on_line)
            if rc == 0:
                print(f"  {C.BGREEN}✓ Cloned{C.RESET}")
                _backup_state.mark(self.username, r["name"], "ok")
                ok_clone += 1
            else:
                print(f"  {C.BRED}✗ Failed: {err}{C.RESET}")
                _backup_state.mark(self.username, r["name"], "failed", err)
                failed += 1

        # ── Update existing repos ──────────────────────────────────────────────
        if to_update:
            print(f"\n  {C.BCYAN}━━ Updating {len(to_update)} existing repos ━━{C.RESET}")
        for r in to_update:
            repo_path = str(bdir / r["name"])
            print(f"\n  {C.BWHITE}↻ {r['name']}{C.RESET}", end="  ", flush=True)
            def on_ln(l): print(f"\n    {C.DIM}{l}{C.RESET}", end="", flush=True)
            rc, msg = CloneEngine.update(repo_path, on_line=on_ln)
            print()
            if rc == 0:
                print(f"  {C.BGREEN}✓ Updated{C.RESET}")
                _backup_state.mark(self.username, r["name"], "updated")
                ok_update += 1
            else:
                print(f"  {C.BRED}✗ Update failed: {msg}{C.RESET}")
                _backup_state.mark(self.username, r["name"], "failed", msg)
                failed += 1

        # ── Summary ────────────────────────────────────────────────────────────
        self._sep()
        print(f"\n  {C.BBLUE}Backup complete{C.RESET}")
        print(f"  {C.BGREEN}✓ Cloned  : {ok_clone}{C.RESET}")
        print(f"  {C.BYELLOW}↻ Updated : {ok_update}{C.RESET}")
        if failed: print(f"  {C.BRED}✗ Failed  : {failed}{C.RESET}")
        print(f"  {C.DIM}Location  : {bdir}{C.RESET}")

    def _do_browse_backup(self):
        """Interactive local backup directory browser."""
        self._header("Browse Backup Directory", "📁")

        # Choose root
        default_dir = str(BACKUP_ROOT / self.username) if self.username else str(BACKUP_ROOT)
        start = self._prompt(f"Directory to browse [{default_dir}]", default_dir)
        cwd   = Path(start).expanduser().resolve()

        while True:
            if not cwd.exists():
                print(f"  {C.BRED}Path does not exist: {cwd}{C.RESET}"); return

            print(f"\n  {C.BCYAN}📁 {cwd}{C.RESET}")
            self._sep("─", 70)

            entries = sorted(cwd.iterdir(), key=lambda p: (p.is_file(), p.name.lower()))
            dirs    = [e for e in entries if e.is_dir()]
            files   = [e for e in entries if e.is_file()]

            if cwd != cwd.parent:
                print(f"  {C.DIM}  0.{C.RESET}  {C.BYELLOW}..{C.RESET}  {C.DIM}(parent){C.RESET}")

            for i, d in enumerate(dirs, 1):
                is_git = (d / ".git").exists()
                badge  = f" {C.BGREEN}[git]{C.RESET}" if is_git else ""
                state_info = ""
                if is_git:
                    ustate = _backup_state.get_user(self.username)
                    info = ustate.get(d.name, {})
                    if info.get("status") == "ok":
                        state_info = f" {C.BGREEN}[bk ok]{C.RESET}"
                    elif info.get("status") == "updated":
                        state_info = f" {C.BYELLOW}[updated]{C.RESET}"
                    elif info.get("status") == "failed":
                        state_info = f" {C.BRED}[failed]{C.RESET}"
                size_str = ""
                try:
                    sz = sum(f.stat().st_size for f in d.rglob('*') if f.is_file())
                    size_str = f"  {C.DIM}{fmt_size(sz)}{C.RESET}"
                except: pass
                print(f"  {C.DIM}{i:>3}.{C.RESET}  {C.BBLUE}📁 {d.name}{C.RESET}{badge}{state_info}{size_str}")

            offset = len(dirs) + 1
            for i, f in enumerate(files, offset):
                sz = fmt_size(f.stat().st_size)
                print(f"  {C.DIM}{i:>3}.{C.RESET}  {C.DIM}📄 {f.name}  {sz}{C.RESET}")

            self._sep("─", 70)
            print(f"  {C.DIM}Enter # to navigate into dir, 0 for parent, 'q' to quit browser{C.RESET}")
            choice = self._prompt("Navigate")
            if choice.lower() in ("q","quit","exit"): return
            if choice == "0":
                cwd = cwd.parent; continue
            if choice.isdigit():
                idx = int(choice) - 1
                if 0 <= idx < len(dirs):
                    cwd = dirs[idx]; continue
            print(f"  {C.DIM}Invalid choice.{C.RESET}")

    def _do_readme(self):
        self._header("View README", "📖")
        repo = self._pick_repo("Repository")
        if not repo: return
        with Loader(f"Fetching README for {repo}"):
            content = self.api.readme(self.username, repo)
        if not content:
            print(f"  {C.BRED}No README found.{C.RESET}"); return
        print(f"\n{C.DIM}{'─'*70}{C.RESET}")
        for line in content.split("\n"):
            if line.startswith("### "):   print(f"  {C.BBLUE}{C.BOLD}{line[4:]}{C.RESET}")
            elif line.startswith("## "): print(f"  {C.BCYAN}{C.BOLD}{line[3:]}{C.RESET}")
            elif line.startswith("# "):  print(f"\n  {C.BMAGENTA}{C.BOLD}{line[2:]}{C.RESET}\n")
            elif line.startswith("```"): print(f"  {C.DIM}{line}{C.RESET}")
            elif line.startswith(("- ","* ")): print(f"  {C.BYELLOW}•{C.RESET} {line[2:]}")
            else:
                w = term_size()[0] - 6
                for chunk in textwrap.wrap(line, w) or [""]: print(f"  {chunk}")
        print(f"{C.DIM}{'─'*70}{C.RESET}")

    def _do_issues(self):
        self._header("View Issues", "🐛")
        repo = self._pick_repo("Repository")
        if not repo: return
        state = self._prompt("State [open/closed/all]", "open")
        with Loader(f"Fetching {state} issues"):
            issues = self.api.issues(self.username, repo, state)
        if not issues:
            print(f"  {C.DIM}No {state} issues.{C.RESET}"); return
        self._sep()
        for iss in issues:
            num   = f"{C.DIM}#{iss['number']}{C.RESET}"
            title = truncate(iss.get("title",""), 55)
            user  = iss.get("user",{}).get("login","?")
            upd   = ago(iss.get("updated_at"))
            col   = C.BGREEN if iss.get("state")=="open" else C.BRED
            icon  = "●" if iss.get("state")=="open" else "✕"
            labels = " ".join(f"[{l['name']}]" for l in iss.get("labels",[])[:3])
            print(f"  {col}{icon}{C.RESET}  {num}  {C.BWHITE}{title:<55}{C.RESET}  "
                  f"{C.BBLUE}{labels}{C.RESET}  {C.DIM}@{user} · {upd}{C.RESET}")
        self._sep()
        print(f"  {C.DIM}{len(issues)} issues shown{C.RESET}")

    def _do_releases(self):
        self._header("Releases & Downloads", "📦")
        repo = self._pick_repo("Repository")
        if not repo: return
        with Loader("Fetching releases"):
            releases = self.api.releases(self.username, repo)
        if not releases:
            print(f"  {C.DIM}No releases found.{C.RESET}"); return
        for rel in releases:
            tag  = rel.get("tag_name","?")
            name = rel.get("name") or tag
            pub  = fmt_date(rel.get("published_at"))
            pre  = f" {C.BYELLOW}[pre-release]{C.RESET}" if rel.get("prerelease") else ""
            print(f"\n  {C.BWHITE}{C.BOLD}{name}{C.RESET}  {C.DIM}{tag} · {pub}{C.RESET}{pre}")
            if rel.get("body"):
                print(f"  {C.DIM}{(rel['body'] or '')[:100].replace(chr(10),' ')}…{C.RESET}")
            for a in rel.get("assets",[]):
                sz  = fmt_size(a.get("size"))
                dl  = fmt_num(a.get("download_count",0))
                print(f"    {C.BCYAN}↓{C.RESET}  {a['name']:<40}  {C.DIM}{sz} · {dl} downloads{C.RESET}")
                want = self._prompt(f"Download {a['name']}? [y/N]","n")
                if want.lower()=="y":
                    dest  = self._prompt("Save to",".")
                    fpath = os.path.join(dest, a["name"])
                    self._download(a["browser_download_url"], fpath)

    def _download(self, url, path):
        print(f"  {C.DIM}Downloading to {path}…{C.RESET}")
        try:
            with requests.get(url, stream=True, timeout=60) as r:
                r.raise_for_status()
                total = int(r.headers.get("Content-Length",0))
                done  = 0
                with open(path,"wb") as f:
                    for chunk in r.iter_content(65536):
                        f.write(chunk); done += len(chunk)
                        if total:
                            pct = done/total; bar = int(30*pct)
                            print(f"\r  [{'█'*bar}{'░'*(30-bar)}] {pct*100:.0f}%  {fmt_size(done)}/{fmt_size(total)}",
                                  end="",flush=True)
            print(f"\n  {C.BGREEN}✓ Saved to {path}{C.RESET}")
        except Exception as e:
            print(f"\n  {C.BRED}✗ Download failed: {e}{C.RESET}")

