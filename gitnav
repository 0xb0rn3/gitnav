def strip_ansi(s):   return re.sub(r'\033\[[0-9;]*[mABCDEFGHJKSTsu]', '', s)
def visible_len(s):  return len(strip_ansi(s))
def truncate(s, n):
    p = strip_ansi(s)
    return p if len(p) <= n else p[:n-1] + "…"
def pad_to(s, n):
    raw = strip_ansi(s)
    padding = max(0, n - len(raw))
    return s + " " * padding

def fmt_size(b):
    if b is None: return "—"
    for u in ("B", "KB", "MB", "GB"):
        if b < 1024: return f"{b:.0f} {u}"
        b /= 1024
    return f"{b:.1f} TB"

def fmt_num(n):
    if n is None: return "—"
    if n >= 1_000_000: return f"{n/1_000_000:.1f}M"
    if n >= 1_000:     return f"{n/1_000:.1f}k"
    return str(n)

def fmt_date(s):
    if not s: return "—"
    try:    return datetime.strptime(s, "%Y-%m-%dT%H:%M:%SZ").strftime("%Y-%m-%d")
    except: return s[:10]

def ago(s):
    if not s: return "—"
    try:
        sec = (datetime.utcnow() - datetime.strptime(s, "%Y-%m-%dT%H:%M:%SZ")).total_seconds()
        if sec < 60:    return "just now"
        if sec < 3600:  return f"{int(sec//60)}m ago"
        if sec < 86400: return f"{int(sec//3600)}h ago"
        return f"{int(sec//86400)}d ago"
    except: return s[:10]

def fmt_ts():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

# ── Backup state persistence ───────────────────────────────────────────────────
class BackupState:
    """Tracks per-user backup state: timestamp, success/fail per repo."""
    def __init__(self):
        self._data = {}
        self._load()

    def _load(self):
        if STATE_FILE.exists():
            try:
                with open(STATE_FILE) as f:
                    self._data = json.load(f)
            except Exception:
                self._data = {}

    def _save(self):
        try:
            STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
            with open(STATE_FILE, "w") as f:
                json.dump(self._data, f, indent=2)
        except Exception:
            pass

    def get_user(self, username):
        return self._data.get(username, {})

    def mark(self, username, repo, status, message=""):
        if username not in self._data:
            self._data[username] = {}
        self._data[username][repo] = {
            "status": status,        # "ok" | "failed" | "updated"
            "ts": fmt_ts(),
            "msg": message,
        }
        self._save()

    def is_cloned(self, username, repo, backup_dir):
        """True if repo dir exists and has a .git inside it."""
        repo_path = Path(backup_dir) / repo
        return (repo_path / ".git").exists()

_backup_state = BackupState()

# ── Multi-token pool ───────────────────────────────────────────────────────────
class TokenPool:
    """Round-robin token rotation with per-token rate-limit tracking."""
    def __init__(self, tokens=None):
        self._tokens  = tokens or []       # list of token strings
        self._idx     = 0
        self._lock    = threading.Lock()
        self._exhausted = set()            # indices of exhausted tokens

    def add(self, token_str):
        """Accept comma or colon separated tokens."""
        for t in re.split(r"[,;:]+", token_str):
            t = t.strip()
            if t:
                self._tokens.append(t)

    def current(self):
        if not self._tokens: return None
        return self._tokens[self._idx % len(self._tokens)]

    def rotate(self, mark_exhausted=False):
        with self._lock:
            if mark_exhausted:
                self._exhausted.add(self._idx % len(self._tokens))
            if len(self._exhausted) >= len(self._tokens):
                return False              # all tokens exhausted
            self._idx = (self._idx + 1) % len(self._tokens)
            # skip exhausted tokens
            for _ in range(len(self._tokens)):
                if (self._idx % len(self._tokens)) not in self._exhausted:
                    break
                self._idx += 1
            return True

    def count(self): return len(self._tokens)
    def exhausted_count(self): return len(self._exhausted)
    def fresh_count(self): return max(0, len(self._tokens) - len(self._exhausted))

_token_pool = TokenPool()

# ── GitHub API ────────────────────────────────────────────────────────────────
class GitHubAPI:
    def __init__(self, token=None):
        self.session = requests.Session()
        self.session.headers.update({
            "Accept":               "application/vnd.github+json",
            "X-GitHub-Api-Version": "2022-11-28",
        })
        self._token_override = token
        self._set_auth()
        self._cache = {}
        self.rate_remaining  = None
        self.rate_reset_ts   = None
        self.rate_limit_val  = None

    def _set_auth(self):
        tok = self._token_override or _token_pool.current()
        if tok:
            self.session.headers["Authorization"] = f"Bearer {tok}"
        else:
            self.session.headers.pop("Authorization", None)

    def _handle_rate(self, headers):
        rem   = headers.get("X-RateLimit-Remaining")
        reset = headers.get("X-RateLimit-Reset")
        lim   = headers.get("X-RateLimit-Limit")
        if rem   is not None: self.rate_remaining = int(rem)
        if reset is not None: self.rate_reset_ts  = int(reset)
        if lim   is not None: self.rate_limit_val = int(lim)

    def _get(self, url, params=None, no_cache=False, retry=3):
        key = url + str(params)
        if not no_cache and key in self._cache:
            return self._cache[key]

        last_err = None
        for attempt in range(retry):
            self._set_auth()
            try:
                r = self.session.get(url, params=params, timeout=TIMEOUT)
                self._handle_rate(r.headers)

                # Rate limited — try to rotate token or wait
                if r.status_code in (403, 429):
                    wait = max(0, self.rate_reset_ts - int(time.time())) if self.rate_reset_ts else 60
                    # Try token rotation first
                    if _token_pool.count() > 1 and _token_pool.fresh_count() > 1:
                        _token_pool.rotate(mark_exhausted=True)
                        self._set_auth()
                        time.sleep(0.3)
                        continue
                    # No rotation possible — wait
                    raise RuntimeError(f"Rate limited (403/429). Reset in {wait}s. "
                                       f"Add more tokens with -t tok1,tok2 to rotate.")

                r.raise_for_status()
                data = r.json()
                self._cache[key] = data
                return data

            except RuntimeError:
                raise
            except requests.exceptions.Timeout:
                last_err = RuntimeError("Request timed out.")
                if attempt < retry - 1: time.sleep(1.5 * (attempt + 1))
            except requests.exceptions.ConnectionError:
                last_err = RuntimeError("Cannot connect to GitHub API.")
                if attempt < retry - 1: time.sleep(2.0 * (attempt + 1))
            except requests.exceptions.HTTPError as e:
                code = e.response.status_code
                if code == 404: raise RuntimeError("Not found (404).")
                if code == 401: raise RuntimeError("Bad credentials (401).")
                last_err = RuntimeError(f"HTTP {code}")
                if attempt < retry - 1: time.sleep(1.0)

        raise last_err or RuntimeError("Unknown error.")

    def user(self, username):    return self._get(f"{API_BASE}/users/{username}")
    def repos(self, username, page=1, per_page=100):
        return self._get(f"{API_BASE}/users/{username}/repos",
                         params={"per_page": per_page, "page": page, "sort": "updated"})
    def all_repos(self, username):
        all_r, page = [], 1
        while True:
            batch = self.repos(username, page=page)
            if not batch: break
            all_r.extend(batch)
            if len(batch) < 100: break
            page += 1
        return all_r
    def readme(self, username, repo):
        try:
            import base64
            data = self._get(f"{API_BASE}/repos/{username}/{repo}/readme")
            return base64.b64decode(data["content"]).decode("utf-8", errors="replace")
        except Exception:
            return None
    def issues(self, username, repo, state="open"):
        return self._get(f"{API_BASE}/repos/{username}/{repo}/issues",
                         params={"state": state, "per_page": 50})
    def releases(self, username, repo):
        return self._get(f"{API_BASE}/repos/{username}/{repo}/releases",
                         params={"per_page": 20})
    def rate_limit(self):
        return self._get(f"{API_BASE}/rate_limit", no_cache=True)
    def clear_cache(self): self._cache.clear()

# ── Clone engine with rate-bypass strategies ───────────────────────────────────
class CloneEngine:
    """
    Wraps `git clone` with several speed/rate-bypass strategies:
      full       — standard full clone (default)
      blobless   — --filter=blob:none  (tree+commits local, blobs on demand)
      treeless   — --filter=tree:0     (commits local only, trees+blobs on demand)
      shallow    -- --depth N          (last N commits only)

    Also supports:
      --jobs N   — parallel pack-object threads
      retry      — exponential backoff on transient failures
      update     — git fetch --all + git pull on existing repos
    """

    STRATEGIES = {
        "full":     [],
        "blobless": ["--filter=blob:none"],
        "treeless": ["--filter=tree:0"],
        "shallow":  ["--depth", "1"],         # depth filled in at call time
    }

    @staticmethod
    def _git_env():
        """Env overrides to maximise clone throughput."""
        env = os.environ.copy()
        env["GIT_HTTP_LOW_SPEED_LIMIT"]  = "1024"   # abort if <1KB/s
        env["GIT_HTTP_LOW_SPEED_TIME"]   = "30"      # … for 30 seconds
        env["GIT_HTTP_CONNECT_TIMEOUT"]  = "30"
        env["GCM_INTERACTIVE"]           = "never"   # suppress credential UI
        return env

    @staticmethod
    def clone(url, dest, strategy="blobless", depth=1, jobs=4,
              on_line=None, retry=3):
        """
        Clone `url` into `dest`.
        on_line(str) callback receives each stderr line as it arrives.
        Returns (returncode, last_error_line).
        """
        flags = CloneEngine.STRATEGIES.get(strategy, []).copy()
        if strategy == "shallow":
            # Replace placeholder with actual depth
            idx = flags.index("--depth") + 1 if "--depth" in flags else -1
            if idx >= 0: flags[idx] = str(depth)
            else: flags = ["--depth", str(depth)]

        base_cmd = ["git", "clone", "--progress",
                    f"--jobs={jobs}", "--no-local", url, dest]
        cmd = base_cmd[:3] + flags + base_cmd[3:]

        last_err = ""
        for attempt in range(retry):
            if os.path.exists(dest) and attempt > 0:
                # Partial clone dir — remove before retry
                shutil.rmtree(dest, ignore_errors=True)

            try:
                proc = subprocess.Popen(
                    cmd, stderr=subprocess.PIPE, stdout=subprocess.PIPE,
                    text=True, env=CloneEngine._git_env()
                )
                for line in proc.stderr:
                    line = line.rstrip()
                    if line:
                        last_err = line
                        if on_line: on_line(line)
                proc.wait()

                if proc.returncode == 0:
                    return 0, ""

                # Transient network errors → retry
                transient = any(k in last_err.lower() for k in
                                ("connection reset","timed out","unable to connect",
                                 "ssl","eof","broken pipe","network"))
                if transient and attempt < retry - 1:
                    wait = 3 * (attempt + 1)
                    if on_line: on_line(f"[retry {attempt+1}/{retry-1}] waiting {wait}s…")
                    time.sleep(wait)
                    continue

                return proc.returncode, last_err

            except FileNotFoundError:
                return -1, "git not found. Please install git."

        return -1, last_err

    @staticmethod
    def update(repo_path, on_line=None):
        """
        For an already-cloned repo: fetch all remotes + pull current branch.
        Returns (returncode, message).
        """
        env = CloneEngine._git_env()
        steps = [
            (["git", "-C", repo_path, "remote", "update", "--prune"], "Fetching remote updates"),
            (["git", "-C", repo_path, "pull", "--ff-only"],            "Fast-forward pull"),
        ]
        for cmd, desc in steps:
            if on_line: on_line(f"  {desc}…")
            try:
                proc = subprocess.run(cmd, capture_output=True, text=True, env=env)
                out = (proc.stdout + proc.stderr).strip()
                if on_line and out:
                    for ln in out.split("\n"):
                        if ln.strip(): on_line(f"  {ln}")
                if proc.returncode != 0:
                    return proc.returncode, out
            except FileNotFoundError:
                return -1, "git not found."
        return 0, "Up to date."

# ── Spinner loader ─────────────────────────────────────────────────────────────
class Loader:
    FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    def __init__(self, msg="Loading"):
        self.msg   = msg
        self._stop = threading.Event()
        self._t    = None
    def _spin(self):
        idx = 0
        while not self._stop.is_set():
            f = self.FRAMES[idx % len(self.FRAMES)]
            print(f"\r  {C.BCYAN}{f}{C.RESET} {C.DIM}{self.msg}…{C.RESET}   ", end="", flush=True)
            idx += 1; time.sleep(0.08)
        print(f"\r{' '*60}\r", end="", flush=True)
    def start(self):
        cursor_hide()
        self._t = threading.Thread(target=self._spin, daemon=True)
        self._t.start(); return self
    def stop(self, ok=True):
        self._stop.set()
        if self._t: self._t.join()
        cursor_show()
        if ok: print(f"  {C.BGREEN}✓{C.RESET} {self.msg}")
    def __enter__(self): return self.start()
    def __exit__(self, *_): self.stop()

