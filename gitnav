    def __init__(self, api, username=""):
        self.api      = api
        self.username = username
        self.repos    = []
        self.sel      = 0
        self.content  = []
        self.scroll   = 0
        self.status   = ""
        self.cols, self.rows = term_size()
        signal.signal(signal.SIGWINCH, self._on_resize)

    def _on_resize(self, *_):
        self.cols, self.rows = term_size()
        self._full_redraw()

    # ── Raw keyboard input ──────────────────────────────────────────────────────
    def _getch(self):
        import tty
        fd  = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        try:
            tty.setraw(fd)
            ch = sys.stdin.read(1)
            if ch == "\033":
                ch2 = sys.stdin.read(1)
                if ch2 == "[":
                    ch3 = sys.stdin.read(1)
                    if ch3 in ("5","6"):
                        sys.stdin.read(1)
                    return f"\033[{ch3}"
                return ch + ch2
            return ch
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)

    def _readline_raw(self, prompt=""):
        import tty
        fd  = sys.stdin.fileno()
        old = termios.tcgetattr(fd)
        buf = []
        cursor_show()
        print(f"{C.BYELLOW}{prompt}{C.RESET}", end="", flush=True)
        try:
            tty.setraw(fd)
            while True:
                ch = sys.stdin.read(1)
                if ch in ("\r","\n"): break
                if ch in ("\x7f","\x08"):
                    if buf: buf.pop(); print("\b \b",end="",flush=True)
                elif ch == "\x03": buf=[]; break
                elif ord(ch)>=32: buf.append(ch); print(ch,end="",flush=True)
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
        cursor_hide()
        return "".join(buf)

    # ── Layout helpers ──────────────────────────────────────────────────────────
    def _content_rect(self):
        return 4, self.SIDEBAR_W + 2, self.rows - 5, self.cols - self.SIDEBAR_W - 3

    def _ask(self, question, default=""):
        tr, lc, h, _ = self._content_rect()
        pr = tr + h - 1
        move_to(pr, lc); erase_line()
        ans = self._readline_raw(f"  {question}: ")
        move_to(pr, lc); erase_line()
        return ans or default

    def _ask_choice(self, question, choices, default=""):
        """Display numbered list of choices and read selection."""
        tr, lc, h, w = self._content_rect()
        start_row = tr + h - len(choices) - 2
        for i, c in enumerate(choices):
            move_to(start_row + i, lc); erase_line()
            print(f"  {C.DIM}{i+1}){C.RESET} {c}", end="", flush=True)
        ans = self._ask(question, default)
        for i in range(len(choices) + 1):
            move_to(start_row + i, lc); erase_line()
        return ans

    def _repo_picker(self, prompt="Repo name or # number"):
        if not self.repos: return None
        val = self._ask(prompt)
        if not val: return None
        if val.isdigit():
            idx = int(val)-1
            if 0<=idx<len(self.repos): return self.repos[idx]["name"]
        for r in self.repos:
            if r["name"]==val: return val
        matches = [r["name"] for r in self.repos if val.lower() in r["name"].lower()]
        if len(matches)==1: return matches[0]
        if matches:
            self._set_content(
                [f"{C.BYELLOW}Did you mean:{C.RESET}"] +
                [f"  {C.DIM}{i+1}.{C.RESET} {m}" for i,m in enumerate(matches[:10])] +
                ["", f"  {C.DIM}Enter exact name or number{C.RESET}"]
            )
            return self._ask("Exact name")
        return val

    # ── Threaded loader ─────────────────────────────────────────────────────────
    def _run_with_loader(self, msg, fn, *args, **kwargs):
        FRAMES = ["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
        result = [None]; error = [None]; done = threading.Event()

        def worker():
            try:    result[0] = fn(*args, **kwargs)
            except Exception as e: error[0] = e
            finally: done.set()

        threading.Thread(target=worker, daemon=True).start()
        tr, lc, h, w = self._content_rect()
        cr = tr + h//2
        cc = lc + max(0, (w-len(msg)-10)//2)
        idx = 0
        while not done.is_set():
            f = FRAMES[idx % len(FRAMES)]
            move_to(cr, cc)
            print(f"{C.BCYAN}{f}{C.RESET}  {C.DIM}{msg}…{C.RESET}      ", end="", flush=True)
            idx += 1; time.sleep(0.08)
        move_to(cr, cc); print(" "*(len(msg)+20), end="", flush=True)
        if error[0]: raise error[0]
        return result[0]

    # ── Drawing ─────────────────────────────────────────────────────────────────
    def _draw_frame(self):
        w, h = self.cols, self.rows
        sw   = self.SIDEBAR_W
        A    = C.BCYAN; R = C.RESET

        # Outer border
        move_to(1,1); print(f"{A}╔{'═'*(w-2)}╗{R}",end="",flush=True)
        for r in range(2,h+1):
            move_to(r,1);  print(f"{A}║{R}",end="",flush=True)
            move_to(r,w);  print(f"{A}║{R}",end="",flush=True)
        move_to(h,1); print(f"{A}╚{'═'*(w-2)}╝{R}",end="",flush=True)

        # Title bar row 2 — with rate limit
        rem  = self.api.rate_remaining
        lim  = self.api.rate_limit_val
        toks = _token_pool.count()
        title = f" 🚀 GitNav v{VERSION} "
        user  = f" @{self.username} " if self.username else ""

        rl_col = C.BGREEN if (rem or 0) > 100 else (C.BYELLOW if (rem or 0) > 20 else C.BRED)
        rl_part = ""
        if rem is not None:
            rl_part = f" {C.DIM}│{R} {rl_col}{rem}{R}{C.DIM}/{lim or '?'} reqs{R}"
            if toks > 0:
                rl_part += f" {C.DIM}│{R} {C.BCYAN}tokens:{_token_pool.fresh_count()}/{toks}{R}"

        rl_plain = strip_ansi(rl_part)
        user_plain = strip_ansi(user)
        title_plain = strip_ansi(title)
        gap = " " * max(0, w - 4 - len(title_plain) - len(user_plain) - len(rl_plain))
        move_to(2,2)
        print(f"{C.BG_BBLUE}{C.BWHITE}{C.BOLD}{title}{R}{C.DIM}{rl_part}{gap}{A}{user}{R}",
              end="", flush=True)

        # Divider row 3
        move_to(3,1); print(f"{A}╠{'═'*sw}╦{'═'*(w-sw-3)}╣{R}",end="",flush=True)

        # Sidebar divider
        for r in range(4, h):
            move_to(r, sw+1); print(f"{A}║{R}",end="",flush=True)

        # Status bar row h-1 and h
        move_to(h-1,1); print(f"{A}╠{'═'*(w-2)}╣{R}",end="",flush=True)
        move_to(h,2)
        keys = (f" {C.DIM}↑↓{R} nav  {C.DIM}Enter/Space{R} select  "
                f"{C.DIM}PgUp/Dn{R} scroll  {C.DIM}r{R} refresh  {C.DIM}b{R} backup  {C.DIM}q{R} quit")
        stat = f"  {C.BYELLOW}{self.status[:max(0,w-100)]}{R}" if self.status else ""
        print(f"{keys}{stat}", end="", flush=True)

    def _draw_sidebar(self):
        sw = self.SIDEBAR_W
        move_to(4,2); print(f"{C.GRAY} ▸ MENU{C.RESET}",end="",flush=True)

        # Backup dir indicator
        bdir = BACKUP_ROOT / self.username if self.username else None
        bk_badge = ""
        if bdir and bdir.exists():
            n = sum(1 for d in bdir.iterdir() if (d/".git").exists()) if bdir.is_dir() else 0
            if n: bk_badge = f"{C.BGREEN} [{n}bk]{C.RESET}"

        if bk_badge:
            move_to(5, 2)
            print(f"  {C.DIM}backup:{C.RESET}{bk_badge}      ", end="", flush=True)
            sidebar_start = 6
        else:
            sidebar_start = 5

        for i,(emoji,label) in enumerate(self.MENU_ITEMS):
            r = sidebar_start + i
            if r >= self.rows-2: break
            move_to(r,2)
            item_col = self._ITEM_COLORS.get(label, C.BWHITE)
            if i == self.sel:
                inner = f" {emoji} {label}"
                padding = max(0, sw - 4 - len(inner))
                print(f"{C.BG_BBLUE}{C.BWHITE}{C.BOLD}{inner}{' '*padding} {C.RESET}",
                      end="",flush=True)
            else:
                inner = f" {emoji} {label}"
                padding = max(0, sw - 4 - len(inner))
                print(f"{item_col}{inner}{C.RESET}{' '*padding}", end="",flush=True)

    def _draw_content(self):
        tr, lc, h, w = self._content_rect()
        visible = self.content[self.scroll : self.scroll+h]

        # Scrollbar
        total = len(self.content)
        if total > h:
            sb_col = max(1, round(h * h / total))
            sb_top = round(self.scroll * h / total)
        else:
            sb_col = h; sb_top = 0

        for i in range(h):
            move_to(tr+i, lc); erase_to_eol()
            if i < len(visible):
                print(truncate(visible[i], w-1), end="", flush=True)
            # Scrollbar in the rightmost column of content area
            sc = lc + w - 1
            move_to(tr+i, sc)
            if total > h:
                ch = "█" if sb_top <= i < sb_top + sb_col else "░"
                print(f"{C.DIM}{ch}{C.RESET}", end="", flush=True)

    def _set_content(self, lines):
        self.content = lines; self.scroll = 0; self._draw_content()

    def _append_content(self, lines):
        self.content.extend(lines)
        self._draw_content()

    def _full_redraw(self):
        self.cols, self.rows = term_size()
        self._draw_frame(); self._draw_sidebar(); self._draw_content()

    # ── Content builders ────────────────────────────────────────────────────────
    def _c_list(self):
        bdir = BACKUP_ROOT / self.username
        lines = [f"{C.BBLUE}{C.BOLD}  📋 Repositories — @{self.username}{C.RESET}",""]
        for i,r in enumerate(self.repos,1):
            lang  = f"{C.BBLUE}[{(r.get('language') or '—'):>10}]{C.RESET}"
            stars = f"{C.BYELLOW}★{fmt_num(r.get('stargazers_count',0)):<5}{C.RESET}"
            name  = f"{C.BWHITE}{r['name']}{C.RESET}"
            priv  = f" {C.BRED}[priv]{C.RESET}" if r.get("private") else ""
            bk    = f" {C.BGREEN}[bk]{C.RESET}" if (bdir / r["name"] / ".git").exists() else ""
            lines.append(f"  {C.DIM}{i:>3}.{C.RESET}  {lang}  {stars}  {name}{priv}{bk}")
        lines += ["", f"  {C.DIM}{len(self.repos)} total  {C.BGREEN}[bk]{C.RESET} {C.DIM}= backed up{C.RESET}"]
        return lines

    def _c_detail(self):
        lines = [f"{C.BBLUE}{C.BOLD}  📋 Detailed Repository List{C.RESET}",""]
        for r in self.repos:
            lang = r.get("language") or "—"; stars=r.get("stargazers_count",0)
            forks=r.get("forks_count",0); size=fmt_size((r.get("size") or 0)*1024)
            upd  = ago(r.get("updated_at")); desc=(r.get("description") or "No description")[:70]
            priv = f" {C.BRED}🔒{C.RESET}" if r.get("private") else ""
            lines.append(f"  {C.BOLD}{C.BWHITE}{r['name']}{C.RESET}{priv}")
            lines.append(f"  {C.DIM}{desc}{C.RESET}")
            lines.append(f"  {C.BYELLOW}★{stars}{C.RESET}  {C.BCYAN}⑂{forks}{C.RESET}  "
                         f"{C.BBLUE}[{lang}]{C.RESET}  {C.DIM}{size} · {upd}{C.RESET}")
            lines.append(f"  {C.DIM}{'·'*60}{C.RESET}")
        return lines

    def _c_stats(self):
        total_stars = sum(r.get("stargazers_count",0) for r in self.repos)
        total_forks = sum(r.get("forks_count",0) for r in self.repos)
        total_size  = sum((r.get("size") or 0) for r in self.repos)*1024
        langs = defaultdict(int)
        for r in self.repos:
            l=r.get("language")
            if l: langs[l]+=1
        public = sum(1 for r in self.repos if not r.get("private"))

        # Local backup stats
        bdir  = BACKUP_ROOT / self.username
        bk_count = 0; bk_size = 0
        if bdir.exists():
            for d in bdir.iterdir():
                if d.is_dir() and (d/".git").exists():
                    bk_count += 1
                    try: bk_size += sum(f.stat().st_size for f in d.rglob('*') if f.is_file())
                    except: pass

        lines  = [f"{C.BBLUE}{C.BOLD}  📊 Repository Statistics{C.RESET}",""]
        lines += [
            f"  {C.BBLUE}Total repos    {C.RESET} {len(self.repos)}",
            f"  {C.BYELLOW}Total stars    {C.RESET} {fmt_num(total_stars)}",
            f"  {C.BCYAN}Total forks    {C.RESET} {fmt_num(total_forks)}",
            f"  {C.BMAGENTA}Total API size {C.RESET} {fmt_size(total_size)}",
            f"  {C.BGREEN}Public         {C.RESET} {public}",
            f"  {C.BRED}Private        {C.RESET} {len(self.repos)-public}",
            "",
            f"  {C.BMAGENTA}Local Backup{C.RESET}",
            f"  {C.BGREEN}Backed up repos{C.RESET} {bk_count} / {len(self.repos)}",
            f"  {C.BYELLOW}Backup disk use{C.RESET} {fmt_size(bk_size) if bk_size else '—'}",
            f"  {C.DIM}Backup location: {bdir}{C.RESET}",
        ]
        if langs:
            lines += ["", f"  {C.BOLD}Language breakdown:{C.RESET}"]
            top = sorted(langs.items(),key=lambda x:-x[1])[:15]
            bw  = 25; mx=max(v for _,v in top)
            for lang,cnt in top:
                filled = round(bw*cnt/mx)
                bar = f"{C.BBLUE}{'█'*filled}{C.DIM}{'░'*(bw-filled)}{C.RESET}"
                lines.append(f"  {lang:<16} {bar} {cnt}")
        return lines

    def _c_profile(self, p):
        lines=[f"{C.BBLUE}{C.BOLD}  👤 User Profile{C.RESET}",""]
        fields=[
            ("Login",p.get("login")),("Name",p.get("name") or "—"),
            ("Bio",p.get("bio") or "—"),("Location",p.get("location") or "—"),
            ("Company",p.get("company") or "—"),("Blog",p.get("blog") or "—"),
            ("Twitter",f"@{p['twitter_username']}" if p.get("twitter_username") else "—"),
            ("Public Repos",fmt_num(p.get("public_repos"))),
            ("Gists",fmt_num(p.get("public_gists"))),
            ("Followers",fmt_num(p.get("followers"))),
            ("Following",fmt_num(p.get("following"))),
            ("Member since",fmt_date(p.get("created_at"))),
        ]
        for k,v in fields:
            lines.append(f"  {C.BBLUE}{k:<16}{C.RESET} {v}")
        return lines

    def _c_issues(self, issues, state):
        lines=[f"{C.BBLUE}{C.BOLD}  🐛 Issues ({state}){C.RESET}",""]
        if not issues:
            lines.append(f"  {C.DIM}No {state} issues found.{C.RESET}"); return lines
        for iss in issues:
            num  = f"{C.DIM}#{iss['number']}{C.RESET}"
            title= truncate(iss.get("title",""),65)
            user = iss.get("user",{}).get("login","?")
            upd  = ago(iss.get("updated_at"))
            col  = C.BGREEN if iss.get("state")=="open" else C.BRED
            icon = "●" if iss.get("state")=="open" else "✕"
            lines.append(f"  {col}{icon}{C.RESET} {num}  {C.BWHITE}{title}{C.RESET}")
            lines.append(f"       {C.DIM}@{user} · {upd}{C.RESET}")
            lines.append("")
        return lines

    def _c_releases(self, releases):
        lines=[f"{C.BBLUE}{C.BOLD}  📦 Releases{C.RESET}",""]
        for rel in releases:
            tag  = rel.get("tag_name","?"); name=rel.get("name") or tag
            pub  = fmt_date(rel.get("published_at"))
            pre  = f" {C.BYELLOW}[pre-release]{C.RESET}" if rel.get("prerelease") else ""
            lines.append(f"  {C.BOLD}{C.BWHITE}{name}{C.RESET}  {C.DIM}{tag} · {pub}{C.RESET}{pre}")
            if rel.get("body"):
                lines.append(f"  {C.DIM}{(rel['body'] or '')[:100].replace(chr(10),' ')}{C.RESET}")
            for a in rel.get("assets",[]):
                sz=fmt_size(a.get("size")); dl=fmt_num(a.get("download_count",0))
                lines.append(f"    {C.BCYAN}↓{C.RESET}  {a['name']:<40}  {C.DIM}{sz} · {dl} dl{C.RESET}")
            lines.append("")
        return lines

    def _c_readme(self, content):
        lines=[f"{C.BBLUE}{C.BOLD}  📖 README{C.RESET}",""]
        if not content:
            lines.append(f"  {C.BRED}No README found.{C.RESET}"); return lines
        for line in content.split("\n"):
            if line.startswith("### "):   lines.append(f"  {C.BBLUE}{C.BOLD}{line[4:]}{C.RESET}")
            elif line.startswith("## "): lines.append(f"  {C.BCYAN}{C.BOLD}{line[3:]}{C.RESET}")
            elif line.startswith("# "):  lines.append(f"  {C.BMAGENTA}{C.BOLD}{line[2:]}{C.RESET}")
            elif line.startswith("```"): lines.append(f"  {C.DIM}{line}{C.RESET}")
            elif line.startswith(("- ","* ")): lines.append(f"  {C.BYELLOW}•{C.RESET} {line[2:]}")
            else: lines.append(f"  {line}")
        return lines

    def _c_clone_output(self, repo, url, strategy, rc, lines_out):
        col = C.BGREEN if rc == 0 else C.BRED
        status = "✓ Clone complete!" if rc == 0 else f"✗ Clone failed (exit {rc})"
        header = [
            f"{C.BBLUE}{C.BOLD}  📥 Clone: {repo}{C.RESET}", "",
            f"  {C.DIM}URL      : {url}{C.RESET}",
            f"  {C.DIM}Strategy : {strategy}{C.RESET}", "",
        ]
        return header + [f"  {C.DIM}{l}{C.RESET}" for l in lines_out] + [
            "", f"  {col}{status}{C.RESET}"
        ]

    def _c_backup(self, repos, bdir, strategy, jobs):
        """
        Run a full backup with live content-pane updates.
        Yields content lines as backup progresses.
        """
        bdir = Path(bdir)
        bdir.mkdir(parents=True, exist_ok=True)

        to_clone  = []
        to_update = []
        for r in repos:
            rp = bdir / r["name"]
            if (rp / ".git").exists(): to_update.append(r)
            else:                      to_clone.append(r)

        lines = [
            f"{C.BBLUE}{C.BOLD}  💾 Backup — @{self.username}{C.RESET}", "",
            f"  {C.BGREEN}To clone : {len(to_clone)}{C.RESET}",
            f"  {C.BYELLOW}To update: {len(to_update)}{C.RESET}",
            f"  {C.DIM}Location : {bdir}{C.RESET}",
            f"  {C.DIM}Strategy : {strategy}  jobs: {jobs}{C.RESET}",
            "",
        ]
        self._set_content(lines)

        ok_clone = ok_update = failed = 0

        # ── Clone new repos ──────────────────────────────────────────────────
        for r in to_clone:
            url  = f"https://github.com/{self.username}/{r['name']}.git"
            dest = str(bdir / r["name"])
            repo_lines = [f"  {C.BWHITE}→ {r['name']}{C.RESET}  {C.DIM}(cloning){C.RESET}"]
            self.content.extend(repo_lines)
            self._draw_content()

            clone_lines = []
            def on_line(l, cl=clone_lines):
                cl.append(l)
                self.content[-1] = f"  {C.DIM}{l}{C.RESET}"
                self._draw_content()

            rc, err = CloneEngine.clone(url, dest, strategy=strategy,
                                        jobs=jobs, on_line=on_line)
            if rc == 0:
                self.content.append(f"  {C.BGREEN}✓ {r['name']} cloned{C.RESET}")
                _backup_state.mark(self.username, r["name"], "ok")
                ok_clone += 1
            else:
                self.content.append(f"  {C.BRED}✗ {r['name']} failed: {err[:60]}{C.RESET}")
                _backup_state.mark(self.username, r["name"], "failed", err)
                failed += 1
            self.content.append("")
            self._draw_content()

        # ── Update existing repos ────────────────────────────────────────────
        for r in to_update:
            rp = str(bdir / r["name"])
            self.content.append(f"  {C.BYELLOW}↻ {r['name']}{C.RESET}  {C.DIM}(updating){C.RESET}")
            self._draw_content()

            def on_ln(l):
                self.content.append(f"    {C.DIM}{l}{C.RESET}")
                self._draw_content()

            rc, msg = CloneEngine.update(rp, on_line=on_ln)
            if rc == 0:
                self.content.append(f"  {C.BGREEN}✓ {r['name']} updated{C.RESET}")
                _backup_state.mark(self.username, r["name"], "updated")
                ok_update += 1
            else:
                self.content.append(f"  {C.BRED}✗ {r['name']} update failed{C.RESET}")
                _backup_state.mark(self.username, r["name"], "failed", msg)
                failed += 1
            self.content.append("")
            self._draw_content()

        # ── Summary ──────────────────────────────────────────────────────────
        self.content += [
            f"  {C.DIM}{'─'*50}{C.RESET}",
            f"  {C.BBLUE}Backup complete{C.RESET}",
            f"  {C.BGREEN}✓ Cloned  : {ok_clone}{C.RESET}",
            f"  {C.BYELLOW}↻ Updated : {ok_update}{C.RESET}",
        ]
        if failed:
            self.content.append(f"  {C.BRED}✗ Failed  : {failed}{C.RESET}")
        self.content.append(f"  {C.DIM}Timestamp : {fmt_ts()}{C.RESET}")
        self.scroll = max(0, len(self.content) - (self._content_rect()[2]))
        self._draw_content()

    def _c_browse_dir(self, start_path):
        """
        Interactive local directory browser inside the TUI content pane.
        Returns when user presses 'q' or navigates all the way out.
        """
        cwd = Path(start_path).expanduser().resolve()

        while True:
            if not cwd.exists():
                self._set_content([f"{C.BRED}  Path not found: {cwd}{C.RESET}"]); return

            try:
                entries = sorted(cwd.iterdir(), key=lambda p: (p.is_file(), p.name.lower()))
            except PermissionError:
                self._set_content([f"{C.BRED}  Permission denied: {cwd}{C.RESET}"]); return

            dirs  = [e for e in entries if e.is_dir()]
            files = [e for e in entries if e.is_file()]

            lines = [
                f"{C.BBLUE}{C.BOLD}  📁 {cwd}{C.RESET}",
                f"  {C.DIM}{'─'*60}{C.RESET}",
            ]
            if cwd.parent != cwd:
                lines.append(f"  {C.DIM} 0.{C.RESET}  {C.BYELLOW}📁 ..{C.RESET}  {C.DIM}(parent){C.RESET}")

            ustate = _backup_state.get_user(self.username) if self.username else {}

            for i, d in enumerate(dirs, 1):
                is_git = (d / ".git").exists()
                git_badge = f" {C.BGREEN}[git]{C.RESET}" if is_git else ""
                st_badge  = ""
                if is_git:
                    info = ustate.get(d.name, {})
                    s = info.get("status","")
                    if s == "ok":      st_badge = f" {C.BGREEN}[ok]{C.RESET}"
                    elif s == "updated": st_badge = f" {C.BYELLOW}[upd]{C.RESET}"
                    elif s == "failed":  st_badge = f" {C.BRED}[fail]{C.RESET}"
                try:
                    sz = sum(f.stat().st_size for f in d.rglob('*') if f.is_file())
                    sz_str = f"  {C.DIM}{fmt_size(sz)}{C.RESET}"
                except: sz_str = ""
                lines.append(f"  {C.DIM}{i:>3}.{C.RESET}  {C.BBLUE}📁 {d.name}{C.RESET}{git_badge}{st_badge}{sz_str}")

            offset = len(dirs) + 1
            for i, f in enumerate(files, offset):
                try: sz_str = f"  {C.DIM}{fmt_size(f.stat().st_size)}{C.RESET}"
                except: sz_str = ""
                lines.append(f"  {C.DIM}{i:>3}.{C.RESET}  {C.GRAY}📄 {f.name}{sz_str}{C.RESET}")

            lines += [
                f"  {C.DIM}{'─'*60}{C.RESET}",
                f"  {C.DIM}# = enter dir   0 = parent   q = back to menu{C.RESET}",
            ]
            self._set_content(lines)

            choice = self._ask("Navigate")
            if not choice or choice.lower() in ("q","quit"): return
            if choice == "0":
                cwd = cwd.parent; continue
            if choice.isdigit():
                idx = int(choice) - 1
                if 0 <= idx < len(dirs):
                    cwd = dirs[idx]; continue
            self.status = "Invalid choice."
            self._draw_frame()

    # ── Dispatch ────────────────────────────────────────────────────────────────
    def _ensure_repos(self):
        if not self.repos:
            self.repos = self._run_with_loader(
                f"Fetching repos for @{self.username}",
                self.api.all_repos, self.username)

    def _dispatch(self):
        action = self.MENU_ITEMS[self.sel][1]

        if action == "Exit":
            self._quit()

        elif action == "List Repos":
            self._ensure_repos(); self._set_content(self._c_list())

        elif action == "Detailed List":
            self._ensure_repos(); self._set_content(self._c_detail())

        elif action == "Search":
            self._ensure_repos()
            q = self._ask("Search term (name / desc / lang)")
            if not q: return
            ql   = q.lower()
            hits = [r for r in self.repos if
                    ql in (r.get("name") or "").lower() or
                    ql in (r.get("description") or "").lower() or
                    ql in (r.get("language") or "").lower()]
            lines=[f"{C.BBLUE}{C.BOLD}  🔍 Search: '{q}'{C.RESET}",""]
            if not hits: lines.append(f"  {C.DIM}No matches.{C.RESET}")
            for r in hits:
                desc=truncate(r.get("description") or "—",55)
                lines.append(f"  {C.BWHITE}{r['name']:<36}{C.RESET}"
                             f"{C.BBLUE}[{(r.get('language') or '—'):<10}]{C.RESET}  "
                             f"{C.DIM}{desc}{C.RESET}")
            self._set_content(lines)

        elif action == "Statistics":
            self._ensure_repos(); self._set_content(self._c_stats())

        elif action == "Clone":
            self._ensure_repos()
            repo = self._repo_picker("Repo to clone (name or #)")
            if not repo: return
            dest = self._ask("Destination directory", ".")

            # Show strategy picker in content pane
            strat_lines = [
                f"{C.BBLUE}{C.BOLD}  📥 Clone: {repo}{C.RESET}", "",
                f"  {C.BWHITE}Select clone strategy:{C.RESET}", "",
                f"  {C.DIM}1){C.RESET} {C.BGREEN}blobless{C.RESET}  — no blobs until needed (recommended)",
                f"  {C.DIM}2){C.RESET} full      — complete clone",
                f"  {C.DIM}3){C.RESET} shallow   — last commit only (fastest)",
                f"  {C.DIM}4){C.RESET} treeless  — commits only (laziest for big repos)",
            ]
            self._set_content(strat_lines)
            strat_map = {"1":"blobless","2":"full","3":"shallow","4":"treeless",
                         "blobless":"blobless","full":"full","shallow":"shallow","treeless":"treeless"}
            s = self._ask("Strategy [1-4 or name]", "1")
            strategy = strat_map.get(s.lower(), "blobless")

            jobs_s = self._ask("Parallel jobs", "4")
            try: jobs = int(jobs_s)
            except: jobs = 4

            url  = f"https://github.com/{self.username}/{repo}.git"
            path = os.path.join(dest, repo)
            out_lines = []

            def on_line(l, ol=out_lines):
                ol.append(l)
                self._set_content(self._c_clone_output(repo, url, strategy, None, ol))

            self._set_content(self._c_clone_output(repo, url, strategy, None, []))
            rc, err = CloneEngine.clone(url, path, strategy=strategy,
                                        jobs=jobs, on_line=on_line)
            self._set_content(self._c_clone_output(repo, url, strategy, rc, out_lines))

        elif action == "Backup All Repos":
            self._ensure_repos()
            repos = self.repos
            if not repos:
                self._set_content([f"{C.BRED}  No repositories found.{C.RESET}"]); return

            default_dir = str(BACKUP_ROOT / self.username)
            bdir = self._ask(f"Backup dir [{default_dir}]", default_dir)

            strat_lines = [
                f"{C.BBLUE}{C.BOLD}  💾 Backup All Repos — @{self.username}{C.RESET}", "",
                f"  {C.BWHITE}Clone strategy for new repos:{C.RESET}", "",
                f"  {C.DIM}1){C.RESET} {C.BGREEN}blobless{C.RESET}  (recommended)",
                f"  {C.DIM}2){C.RESET} full",
                f"  {C.DIM}3){C.RESET} shallow",
                f"  {C.DIM}4){C.RESET} treeless",
            ]
            self._set_content(strat_lines)
            strat_map = {"1":"blobless","2":"full","3":"shallow","4":"treeless",
                         "blobless":"blobless","full":"full","shallow":"shallow","treeless":"treeless"}
            s = self._ask("Strategy [1-4]", "1")
            strategy = strat_map.get(s.lower(), "blobless")

            jobs_s = self._ask("Parallel jobs", "4")
            try: jobs = int(jobs_s)
            except: jobs = 4

            confirm = self._ask(f"Back up {len(repos)} repos? [y/N]", "n")
            if confirm.lower() != "y":
                self._set_content([f"  {C.DIM}Cancelled.{C.RESET}"]); return

            self._c_backup(repos, bdir, strategy, jobs)

        elif action == "Browse Backup Dir":
            default_dir = str(BACKUP_ROOT / self.username) if self.username else str(BACKUP_ROOT)
            start = self._ask(f"Directory [{default_dir}]", default_dir)
            self._c_browse_dir(start)

        elif action == "View README":
            self._ensure_repos()
            repo = self._repo_picker("Repo for README")
            if not repo: return
            content = self._run_with_loader(f"Fetching README for {repo}",
                                            self.api.readme, self.username, repo)
            self._set_content(self._c_readme(content))

        elif action == "Issues":
            self._ensure_repos()
            repo  = self._repo_picker("Repo for issues")
            if not repo: return
            state = self._ask("State [open/closed/all]","open")
            issues= self._run_with_loader(f"Fetching {state} issues",
                                          self.api.issues, self.username, repo, state)
            self._set_content(self._c_issues(issues, state))

        elif action == "Releases":
            self._ensure_repos()
            repo = self._repo_picker("Repo for releases")
            if not repo: return
            rels = self._run_with_loader(f"Fetching releases for {repo}",
                                         self.api.releases, self.username, repo)
            self._set_content(self._c_releases(rels))

        elif action == "Open Browser":
            self._ensure_repos()
            repo = self._ask("Repo name (blank = profile page)","")
            url  = (f"https://github.com/{self.username}/{repo}"
                    if repo else f"https://github.com/{self.username}")
            webbrowser.open(url)
            self._set_content([f"{C.BBLUE}{C.BOLD}  🌐 Opened in Browser{C.RESET}","",
                               f"  {C.BGREEN}✓{C.RESET} {url}"])

        elif action == "User Profile":
            u = self._ask("GitHub username", self.username)
            p = self._run_with_loader(f"Fetching @{u}", self.api.user, u)
            self._set_content(self._c_profile(p))

        elif action == "Refresh":
            self.api.clear_cache(); self.repos=[]
            self._ensure_repos()
            self.status = f"Refreshed · {len(self.repos)} repos"
            self._draw_frame()
            self._set_content([f"{C.BBLUE}{C.BOLD}  🔄 Data Refreshed{C.RESET}","",
                               f"  {C.BGREEN}✓ Cache cleared · {len(self.repos)} repos reloaded.{C.RESET}"])

    # ── Animated login splash ────────────────────────────────────────────────────
    def _login_splash(self):
        clear()
        w, h = self.cols, self.rows
        LOGO = [
            "  ██████╗ ██╗████████╗███╗   ██╗ █████╗ ██╗   ██╗",
            " ██╔════╝ ██║╚══██╔══╝████╗  ██║██╔══██╗██║   ██║",
            " ██║  ███╗██║   ██║   ██╔██╗ ██║███████║██║   ██║",
            " ██║   ██║██║   ██║   ██║╚██╗██║██╔══██║╚██╗ ██╔╝",
            " ╚██████╔╝██║   ██║   ██║ ╚████║██║  ██║ ╚████╔╝ ",
            "  ╚═════╝ ╚═╝   ╚═╝   ╚═╝  ╚═══╝╚═╝  ╚═╝  ╚═══╝  ",
        ]
        COLS = [C.BCYAN, C.BBLUE, C.BMAGENTA, C.BBLUE, C.BCYAN, C.DIM]
        sr   = max(1, h//2 - 7)

        for li, line in enumerate(LOGO):
            move_to(sr+li, max(1, (w-len(line))//2))
            for ch in line:
                print(f"{COLS[li]}{ch}{C.RESET}", end="", flush=True)
                time.sleep(0.003)

        for row_off, text, col in [
            (7, f"🚀 Enhanced GitHub Repository Navigator  v{VERSION}", C.BMAGENTA),
            (8, "oxbv1 | oxborn3  ·  oxborn3.com  ·  contact@oxborn3.com", C.DIM),
            (9, "NEW: backup all repos · blobless clone · token rotation", C.BYELLOW),
        ]:
            move_to(sr+row_off, max(1, (w-len(text))//2))
            print(f"{col}{text}{C.RESET}", flush=True)

        bw  = 42; br = sr + 11; bc = max(1, (w-bw-6)//2)
        for i in range(bw+1):
            move_to(br, bc)
            filled = "█"*i + "░"*(bw-i)
            pct    = int(100*i/bw)
            print(f"{C.BCYAN}{filled}{C.RESET} {C.DIM}{pct:>3}%{C.RESET}", end="", flush=True)
            time.sleep(0.025)
        print()

        prompt_r = br + 2
        while True:
            move_to(prompt_r, max(1,(w-44)//2))
            print(f"{C.BWHITE}  GitHub username:{C.RESET} " + " "*30, end="", flush=True)
            move_to(prompt_r, max(1,(w-44)//2)+18)
            cursor_show()

            import tty
            fd  = sys.stdin.fileno()
            old = termios.tcgetattr(fd)
            buf = []
            try:
                tty.setraw(fd)
                while True:
                    ch = sys.stdin.read(1)
                    if ch in ("\r","\n"): break
                    if ch in ("\x7f","\x08"):
                        if buf: buf.pop(); print("\b \b",end="",flush=True)
                    elif ord(ch)>=32: buf.append(ch); print(ch,end="",flush=True)
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
            cursor_hide()

            u = "".join(buf).strip()
            if not u: continue

            move_to(prompt_r+1, max(1,(w-44)//2))
            print(f"  {C.DIM}Verifying @{u}…{C.RESET}          ", end="", flush=True)
            try:
                self.api.user(u); self.username = u
                move_to(prompt_r+1, max(1,(w-44)//2))
                print(f"  {C.BGREEN}✓ Welcome, @{u}!{C.RESET}          ", flush=True)
                time.sleep(0.7); return
            except Exception as e:
                move_to(prompt_r+1, max(1,(w-44)//2))
                print(f"  {C.BRED}✗ {str(e)[:40]}{C.RESET}          ", flush=True)
                time.sleep(1.2)

    # ── Main event loop ──────────────────────────────────────────────────────────
    def run(self):
        alt_screen(); cursor_hide()
        try:
            if not self.username:
                self._login_splash()
            else:
                try: self.api.user(self.username)
                except Exception as e:
                    main_screen(); cursor_show()
                    print(f"{C.BRED}✗ {e}{C.RESET}"); sys.exit(1)
            clear()
            self.repos = self._run_with_loader(
                f"Loading repos for @{self.username}",
                self.api.all_repos, self.username)
            self._full_redraw()
            self._set_content(self._c_list())

            while True:
                key = self._getch()
                _, _, h, _ = self._content_rect()

                if key in ("q","Q","\x03"):
                    self._quit()
                elif key == "\033[A":   # Up
                    self.sel = (self.sel-1) % len(self.MENU_ITEMS)
                    self._draw_sidebar()
                elif key == "\033[B":   # Down
                    self.sel = (self.sel+1) % len(self.MENU_ITEMS)
                    self._draw_sidebar()
                elif key in ("\r","\n"," "):
                    try:    self._dispatch()
                    except RuntimeError as e:
                        self._set_content([f"{C.BRED}⚠  {e}{C.RESET}"])
                    except Exception as e:
                        self._set_content([f"{C.BRED}Error: {e}{C.RESET}"])
                    self._draw_sidebar()
                elif key == "\033[5":   # PgUp
                    self.scroll = max(0, self.scroll-20)
                    self._draw_content()
                elif key == "\033[6":   # PgDn
                    self.scroll = min(max(0,len(self.content)-h), self.scroll+20)
                    self._draw_content()
                elif key == "r":
                    self.api.clear_cache(); self.repos=[]
                    try:
                        self._ensure_repos()
                        self.status=f"Refreshed · {len(self.repos)} repos"
                        self._draw_frame()
                    except Exception as e:
                        self.status=f"Refresh failed: {e}"
                        self._draw_frame()
                elif key == "b":
                    # Quick-jump to Backup All Repos
                    for i,(e,l) in enumerate(self.MENU_ITEMS):
                        if l == "Backup All Repos": self.sel = i
                    self._draw_sidebar()
                    try: self._dispatch()
                    except Exception as e:
                        self._set_content([f"{C.BRED}Error: {e}{C.RESET}"])
                    self._draw_sidebar()
        finally:
            cursor_show(); main_screen()

    def _quit(self):
        cursor_show(); main_screen()
        print(f"\n  {C.BCYAN}Thanks for using GitNav. Goodbye!{C.RESET}\n")
        sys.exit(0)


